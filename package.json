{
  "name": "reputation360",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/kill-vite-ports.mjs && node scripts/clear-vite-cache.mjs && node scripts/dev.mjs",
    "dev:simple": "node scripts/dev.mjs",
    "dev:kill": "node scripts/kill-vite-ports.mjs",
    "dev:fresh": "node scripts/kill-vite-ports.mjs && node scripts/clear-vite-cache.mjs && node scripts/dev.mjs",
    "dev:vercel": "npx vercel dev",
    "start": "npm run dev",
    "doctor": "node scripts/doctor.mjs",
    "env:init": "node scripts/init-free-scan-env.mjs",
    "check:exports": "node scripts/check-export-reexport.mjs",
    "verify:imports": "node scripts/verify-critical-imports.mjs",
    "verify:dist": "node scripts/verify-production-build.mjs",
    "verify:prerender": "node scripts/verify-prerender-content.mjs",
    "verify:build": "npm run check:exports && npm run verify:imports && npm run verify:prerender && REQUIRE_PUPPETEER_SMOKE=1 npm run verify:dist",
    "postinstall": "node scripts/ensure-puppeteer-chrome.mjs",
    "prebuild": "npm run check:exports && npm run verify:imports",
    "build": "node scripts/dev.mjs build && node scripts/postbuild-spa-routes.mjs && node scripts/emit-spa-per-route-html.mjs && npm run verify:prerender && npm run verify:dist && node scripts/run-react-snap.mjs && node scripts/patch-dist-canonical-from-fspath.mjs && node scripts/verify-dist-html.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs && node scripts/sync-crawl-nav.mjs && node scripts/sync-home-jsonld.mjs",
    "lint": "eslint .",
    "preview": "node scripts/dev.mjs preview",
    "local:prod": "node scripts/dev.mjs build && node scripts/dev.mjs preview",
    "verify:live": "node scripts/verify-live-deploy.mjs",
    "verify:live:about": "node scripts/verify-live-deploy.mjs /about"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.36.1",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.563.0",
    "mini-svg-data-uri": "^1.4.4",
    "motion": "^12.29.2",
    "postgres": "^3.4.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-multi-carousel": "^2.8.6",
    "react-responsive-carousel": "^3.2.23",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "include": [
      "/",
      "/about",
      "/services",
      "/who-we-serve",
      "/who-we-serve/individual",
      "/who-we-serve/financial-advisors",
      "/who-we-serve/executives-and-c-suite-leaders",
      "/who-we-serve/doctors-and-healthcare-professionals",
      "/who-we-serve/lawyers-and-attorneys",
      "/who-we-serve/job-seekers",
      "/who-we-serve/businesses-and-companies",
      "/case-studies",
      "/contact",
      "/free-reputation-scan",
      "/ai-reputation-scan",
      "/blog",
      "/blog/how-to-suppress-negative-content-professionals-guide",
      "/blog/diy-online-reputation-management-complete-guide",
      "/blog/remove-negative-search-results-from-google",
      "/blog/how-long-does-it-take-to-fix-online-reputation",
      "/blog/can-you-remove-news-articles-from-google-search",
      "/blog/how-to-suppress-negative-search-results-reputation360-framework",
      "/blog/rank-positive-content-above-negative-results-reputation360-strategy",
      "/blog/removal-vs-suppression-which-actually-works-reputation360",
      "/blog/old-social-media-posts-showing-up-google-reputation360-guide",
      "/blog/negative-links-cost-jobs-deals-real-cases-reputation360",
      "/blog/remove-court-records-google-reputation360",
      "/blog/crisis-management-reputation-recovery-reputation360-playbook",
      "/blog/linkedin-profile-optimization-search-results-reputation360-checklist",
      "/blog/what-recruiters-google-about-you-reputation360-insider-report",
      "/blog/fix-reputation-before-job-interview-reputation360-guide",
      "/blog/own-your-first-page-control-google-results-reputation360",
      "/blog/why-first-google-result-matters-psychology-reputation360",
      "/blog/hidden-cost-ignoring-online-reputation-reputation360-analysis",
      "/blog/online-reputation-management-best-practices-reputation360-methodology",
      "/blog/roi-reputation-management-what-clients-see-reputation360",
      "/blog/building-positive-google-presence-profile-claiming-guide-reputation360",
      "/blog/monitoring-online-reputation-tools-tactics-reputation360",
      "/blog/social-media-reputation-management-multi-platform-strategy-reputation360",
      "/blog/ai-search-changes-reputation-chatgpt-beyond-reputation360-guide",
      "/resources/guide",
      "/resources/faqs",
      "/privacy-policy",
      "/terms-of-service",
      "/cookie-policy",
      "/refund-policy",
      "/acceptable-use-policy",
      "/terms-of-use",
      "/dmca-copyright-policy"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "skipThirdPartyRequests": true,
    "headless": true,
    "removeBlobs": true,
    "inlineCss": false
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "puppeteer": "^24.43.1",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.4"
  }
}
