# Free Google reputation scan (Vercel serverless: /api/free-scan)
# Copy to .env.local for Vite; set the same vars in the Vercel project for production.

# Free-scan leads: rows go to PostgreSQL tables `free_scan_users` and `free_scans` (see api/lib/db.js).
# Use your host SQL console or psql with this URL to query or export.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# 1 = local free scan works without Google keys (illustrative SERP only). Ignored when VERCEL_ENV=production.
# For real Google results, set GOOGLE_CSE_* below and set this to 0.
FREE_SCAN_RELAXED_CONFIG=1

GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Required for production: live Google Programmable Search (first 3 pages, up to 30 links).
# With FREE_SCAN_RELAXED_CONFIG=1 and no keys, /api/free-scan uses a demo SERP locally only.

RESEND_API_KEY=
# No surrounding quotes in Vercel. Use an address on a domain verified in Resend (https://resend.com/domains).
# Examples: reports@thereputation360.com  OR  Reputation360 <reports@thereputation360.com>
RESEND_FROM_EMAIL=Reputation360 <reports@thereputation360.com>

# Optional: comma-separated browser origins allowed for CORS (defaults include production + localhost).
# FREE_SCAN_ALLOWED_ORIGINS=https://www.thereputation360.com,http://localhost:5173

# Required for the admin/export endpoint:
# /api/free-scan-submissions?token=...&format=json
# /api/free-scan-submissions?token=...&format=csv
FREE_SCAN_ADMIN_TOKEN=

# Vite dev: forward /api to `npx vercel dev` (often http://127.0.0.1:3000)

# Optional: full origin of API when the SPA is not served from the same host as /api
# VITE_FREE_SCAN_API_URL=https://www.thereputation360.com

# AI reputation agent (/api/reputation-agent, /ai-reputation-scan)
# Tavily: web_search + web_fetch — https://tavily.com
TAVILY_API_KEY=
# OpenRouter: LLM for agent reasoning and sentiment summary — https://openrouter.ai
OPENROUTER_API_KEY=
# Optional model (default: google/gemini-2.0-flash-001)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# VITE_REPUTATION_AGENT_API_URL=https://www.thereputation360.com
