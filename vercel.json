{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "thereputation360.com" }],
      "destination": "https://www.thereputation360.com/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "thereputation360.com" }],
      "destination": "https://www.thereputation360.com/:path+",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "reputation360.vercel.app" }],
      "destination": "https://www.thereputation360.com/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "reputation360.vercel.app" }],
      "destination": "https://www.thereputation360.com/:path+",
      "permanent": true
    },
    {
      "source": "/free-risk-scan",
      "destination": "/free-reputation-scan",
      "permanent": true
    },
    {
      "source": "/blog/how-to-remove-or-suppress-negative-search-results-from-google",
      "destination": "/blog/remove-negative-search-results-from-google",
      "permanent": true
    },
    { "source": "/resources/blogs", "destination": "/blog", "permanent": true },
    {
      "source": "/resources/blogs/:slug",
      "destination": "/blog/:slug",
      "permanent": true
    },
    { "source": "/services/negative-link-suppression", "destination": "/services", "permanent": true },
    { "source": "/services/online-reputation-management", "destination": "/services", "permanent": true },
    { "source": "/services/brand-monitoring", "destination": "/services", "permanent": true },
    { "source": "/services/crisis-management", "destination": "/services", "permanent": true },
    { "source": "/services/individuals", "destination": "/who-we-serve/individual", "permanent": true },
    { "source": "/services/financial-advisors", "destination": "/who-we-serve/financial-advisors", "permanent": true },
    { "source": "/services/executives", "destination": "/who-we-serve/executives-and-c-suite-leaders", "permanent": true },
    { "source": "/services/doctors", "destination": "/who-we-serve/doctors-and-healthcare-professionals", "permanent": true },
    { "source": "/services/lawyers", "destination": "/who-we-serve/lawyers-and-attorneys", "permanent": true },
    { "source": "/services/job-seekers", "destination": "/who-we-serve/job-seekers", "permanent": true },
    { "source": "/services/businesses", "destination": "/who-we-serve/businesses-and-companies", "permanent": true },
    { "source": "/case-studies/1", "destination": "/case-studies/executive-and-founder-reputation-management", "permanent": true },
    { "source": "/case-studies/2", "destination": "/case-studies/financial-professional-reputation-recovery", "permanent": true },
    { "source": "/case-studies/3", "destination": "/case-studies/medical-and-healthcare-reputation-management", "permanent": true },
    { "source": "/case-studies/4", "destination": "/case-studies/hr-and-employment-dispute-reputation-management", "permanent": true },
    { "source": "/case-studies/5", "destination": "/case-studies/e-commerce-and-retail-brand-recovery", "permanent": true },
    { "source": "/case-studies/6", "destination": "/case-studies/consumer-electronics-product-crisis-recovery", "permanent": true },
    { "source": "/case-studies/7", "destination": "/case-studies/startup-reputation-recovery-after-funding-controversy", "permanent": true },
    { "source": "/case-studies/8", "destination": "/case-studies/e-commerce-brand-recovery-after-counterfeit-allegations", "permanent": true },
    { "source": "/case-studies/9", "destination": "/case-studies/the-review-that-almost-ended-the-surgeons-career", "permanent": true },
    { "source": "/case-studies/the-surgeon-under-fire", "destination": "/case-studies/the-review-that-almost-ended-the-surgeons-career", "permanent": true },
    { "source": "/case-studies/10", "destination": "/case-studies/the-gp-and-the-misattributed-article", "permanent": true },
    { "source": "/case-studies/11", "destination": "/case-studies/the-litigation-partner-and-the-losing-verdict", "permanent": true },
    { "source": "/case-studies/12", "destination": "/case-studies/the-family-lawyer-and-the-client-vendetta", "permanent": true },
    { "source": "/case-studies/13", "destination": "/case-studies/the-ifa-and-the-collapsed-investment-fund", "permanent": true },
    { "source": "/case-studies/14", "destination": "/case-studies/the-accountant-and-the-wrongful-dismissal-headline", "permanent": true },
    { "source": "/case-studies/15", "destination": "/case-studies/the-graduate-and-the-incident-that-followed-him-online", "permanent": true },
    { "source": "/case-studies/16", "destination": "/case-studies/the-senior-product-manager-and-the-glassdoor-problem", "permanent": true }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/about",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/blog",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/blog/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/contact",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/resources/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/services",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/services/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/case-studies",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/case-studies/:id*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/who-we-serve/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/free-scan.js": {
      "maxDuration": 60
    },
    "api/free-scan-submissions.js": {
      "maxDuration": 60
    },
    "api/reputation-agent.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
